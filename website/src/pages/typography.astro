---
import Base from '../layouts/Base.astro';
---

<Base title="Typography" description="Type system reference for the Creative Technologist Atlas.">

  <section class="container page-header">
    <p class="page-header__eyebrow">Design System</p>
    <h1 class="page-header__title">Typography</h1>
    <p class="page-header__descriptor">
      Fonts, scale, weights, and usage patterns for the Atlas.
    </p>
  </section>

  <!-- ── TYPEFACES ──────────────────────────────────────────── -->
  <section class="container ty-section">
    <h2 class="ty-section__label">Typefaces</h2>

    <div class="ty-faces">

      <div class="ty-face">
        <div class="ty-face__specimen ty-face__specimen--corp-wide">
          Aa
        </div>
        <div class="ty-face__meta">
          <div class="ty-face__name">PP Neue Corp Wide</div>
          <div class="ty-face__role">Display / Hero — <code>--font-display</code> + <code>font-stretch: expanded</code></div>
          <div class="ty-face__cuts">Weights in use: Ultrabold 700–800 · Black 900 · Italic variants</div>
        </div>
      </div>

      <div class="ty-face">
        <div class="ty-face__specimen ty-face__specimen--corp">
          Aa
        </div>
        <div class="ty-face__meta">
          <div class="ty-face__name">PP Neue Corp Normal</div>
          <div class="ty-face__role">Headings — <code>--font-display</code></div>
          <div class="ty-face__cuts">Weights in use: Medium 500 · Ultrabold 700–800 · Black 900 · Italic variants</div>
        </div>
      </div>

      <div class="ty-face">
        <div class="ty-face__specimen ty-face__specimen--montreal">
          Aa
        </div>
        <div class="ty-face__meta">
          <div class="ty-face__name">PP Neue Montreal</div>
          <div class="ty-face__role">Body / UI — <code>--font-sans</code></div>
          <div class="ty-face__cuts">Weights in use: Regular 400 · Medium 500 · Bold 700 · Italic variants</div>
        </div>
      </div>

      <div class="ty-face">
        <div class="ty-face__specimen ty-face__specimen--mono">
          Aa
        </div>
        <div class="ty-face__meta">
          <div class="ty-face__name">PP Neue Montreal Mono</div>
          <div class="ty-face__role">Code / ASCII — <code>--font-mono</code></div>
          <div class="ty-face__cuts">Weights in use: Regular 400 · Medium 500</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── TYPE SCALE ─────────────────────────────────────────── -->
  <section class="container ty-section">
    <h2 class="ty-section__label">Type scale</h2>

    <div class="ty-scale">

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-3xl</span>
          <span class="ty-scale__value">4rem · 64px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--3xl">Hero</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-2xl</span>
          <span class="ty-scale__value">3rem · 48px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--2xl">Display</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-xl</span>
          <span class="ty-scale__value">2.25rem · 36px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--xl">Page title</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-lg</span>
          <span class="ty-scale__value">1.75rem · 28px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--lg">Section heading</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-md</span>
          <span class="ty-scale__value">1.25rem · 20px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--md">Lead / intro text</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-base</span>
          <span class="ty-scale__value">1rem · 16px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--base">Body text</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-sm</span>
          <span class="ty-scale__value">0.875rem · 14px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--sm">Meta / captions</div>
      </div>

      <div class="ty-scale__row">
        <div class="ty-scale__spec">
          <span class="ty-scale__token">--text-xs</span>
          <span class="ty-scale__value">0.75rem · 12px</span>
        </div>
        <div class="ty-scale__sample ty-scale__sample--xs">Labels · tags · badges</div>
      </div>

    </div>
  </section>

  <!-- ── STYLES IN USE ──────────────────────────────────────── -->
  <section class="container ty-section">
    <h2 class="ty-section__label">Styles in use</h2>

    <div class="ty-styles">

      <div class="ty-style">
        <div class="ty-style__label">.text-display — Hero / home headline</div>
        <div class="ty-style__sample text-display">What separates technology<br/>that works from the one that matters?</div>
        <div class="ty-style__spec">PP Neue Corp Wide · 700–800 · expanded · 64px · leading 1.2 · tracking −0.01em</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-title — Page titles</div>
        <div class="ty-style__sample text-title">Thinkers</div>
        <div class="ty-style__spec">PP Neue Corp · 700–800 · 48px · leading 1.35</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-heading — Section headings</div>
        <div class="ty-style__sample text-heading">Read &amp; Watch</div>
        <div class="ty-style__spec">PP Neue Corp · 700 · 36px · leading 1.35</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-subheading — Subheadings</div>
        <div class="ty-style__sample text-subheading">Environmental scientist, systems thinker</div>
        <div class="ty-style__spec">PP Neue Montreal · 500 · 28px · leading 1.35</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-lead — Intro paragraphs</div>
        <div class="ty-style__sample text-lead">Not the stack. Not the velocity. It's the quality of thinking in the moments before a line of code is written.</div>
        <div class="ty-style__spec">PP Neue Montreal · 400 · 20px · leading 1.8</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-body — Standard body</div>
        <div class="ty-style__sample text-body">Donella Meadows co-authored The Limits to Growth in 1972, one of the first attempts to model global resource depletion computationally. The study was controversial — many of its specific predictions were wrong, but its structural insight was correct.</div>
        <div class="ty-style__spec">PP Neue Montreal · 400 · 16px · leading 1.6</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-pull-quote — Article centrepiece</div>
        <div class="ty-style__sample text-pull-quote">"Before you disturb the system in any way, watch how it behaves."</div>
        <div class="ty-style__spec">PP Neue Corp · 400 italic · 36px · leading 1.35 · tracking −0.02em</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-question — Lens core question</div>
        <div class="ty-style__sample text-question">How does the structure of a system shape what's possible within it?</div>
        <div class="ty-style__spec">PP Neue Corp · 400 italic · 28px · leading 1.35 · muted</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-meta — Captions / metadata</div>
        <div class="ty-style__sample text-meta">1941–2001 · Environmental scientist · donellameadows.org</div>
        <div class="ty-style__spec">PP Neue Montreal · 400 · 14px · muted · leading 1.6</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-label — Labels / tags</div>
        <div class="ty-style__sample text-label">The Shoulders</div>
        <div class="ty-style__spec">PP Neue Montreal · 500 · 12px · uppercase · tracking 0.1em</div>
      </div>

      <div class="ty-style">
        <div class="ty-style__label">.text-mono — Code / ASCII data</div>
        <div class="ty-style__sample text-mono">$@B%8&amp;WM#*oahkbdpqwm · --font-mono · 14px</div>
        <div class="ty-style__spec">PP Neue Montreal Mono · 400 · 14px · leading 1.6</div>
      </div>

    </div>
  </section>

  <!-- ── PROSE ──────────────────────────────────────────────── -->
  <section class="container ty-section">
    <h2 class="ty-section__label">Prose — reading column</h2>

    <div class="ty-prose-demo">
      <div class="prose">
        <h2>Signature moment</h2>
        <p>In 1972, Meadows and her colleagues presented <em>The Limits to Growth</em> at a press conference in Washington. The study had been commissioned by the Club of Rome and run on one of the world's most powerful computers at the time.</p>
        <p>The reaction was immediate and hostile. Economists called it pseudoscience. Business leaders called it doomsaying.</p>
        <h3>What they gave us</h3>
        <p><strong>Systems thinking</strong> — the vocabulary for understanding how stocks, flows, feedback loops, and delays produce the counterintuitive behaviors that make complex systems so hard to manage.</p>
        <blockquote>
          <p>The places where interventions seem most powerful are usually least effective.</p>
        </blockquote>
        <ul>
          <li>Stocks accumulate; flows change them</li>
          <li>Feedback loops govern behavior over time</li>
          <li>Delays between cause and effect mislead decision-makers</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── LINE HEIGHTS ───────────────────────────────────────── -->
  <section class="container ty-section">
    <h2 class="ty-section__label">Line heights</h2>

    <div class="ty-leading">

      <div class="ty-leading__row">
        <div class="ty-leading__token">--leading-tight · 1.2</div>
        <div class="ty-leading__sample ty-leading__sample--tight">Display headings and<br/>hero moments where<br/>tight stacking is desired.</div>
      </div>

      <div class="ty-leading__row">
        <div class="ty-leading__token">--leading-snug · 1.35</div>
        <div class="ty-leading__sample ty-leading__sample--snug">Section headings, titles,<br/>pull quotes — readable<br/>but compact.</div>
      </div>

      <div class="ty-leading__row">
        <div class="ty-leading__token">--leading-base · 1.6</div>
        <div class="ty-leading__sample ty-leading__sample--base">Standard body text. Used everywhere<br/>reading comfort matters most.<br/>Balanced for screen reading.</div>
      </div>

      <div class="ty-leading__row">
        <div class="ty-leading__token">--leading-loose · 1.8</div>
        <div class="ty-leading__sample ty-leading__sample--loose">Lead paragraphs and intro text<br/>where extra breathing room<br/>sets a slower, deliberate pace.</div>
      </div>

    </div>
  </section>

</Base>

<style>
  /* ── Page header ───────────────────────────────────────────── */
  .page-header {
    padding-top: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: var(--space-12);
  }

  /* ── Section wrapper ───────────────────────────────────────── */
  .ty-section {
    margin-bottom: var(--space-14);
  }

  .ty-section__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }

  /* ── Typefaces ─────────────────────────────────────────────── */
  .ty-faces {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
  }

  .ty-face {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .ty-face__specimen {
    height: 120px;
    display: flex;
    align-items: center;
    padding-left: var(--space-6);
    font-size: 5rem;
    line-height: 1;
    background: var(--color-rule);
    color: var(--color-ink);
  }

  .ty-face__specimen--corp-wide {
    font-family: var(--font-display);
    font-weight: 800;
    font-stretch: expanded;
  }

  .ty-face__specimen--corp {
    font-family: var(--font-display);
    font-weight: 700;
    font-stretch: normal;
  }

  .ty-face__specimen--montreal {
    font-family: var(--font-sans);
    font-weight: 400;
  }

  .ty-face__specimen--mono {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 4rem;
  }

  .ty-face__meta {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .ty-face__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-base);
  }

  .ty-face__role {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .ty-face__cuts {
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  .ty-face__role code,
  .ty-face__cuts code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-rule);
    padding: 0 4px;
    border-radius: 3px;
  }

  /* ── Scale ─────────────────────────────────────────────────── */
  .ty-scale {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ty-scale__row {
    display: grid;
    grid-template-columns: 200px 1fr;
    align-items: baseline;
    gap: var(--space-6);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-rule);
  }

  .ty-scale__spec {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 4px;
  }

  .ty-scale__token {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ochre);
  }

  .ty-scale__value {
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  .ty-scale__sample {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.15;
    padding: var(--space-2) 0;
  }

  .ty-scale__sample--3xl { font-size: var(--text-3xl); }
  .ty-scale__sample--2xl { font-size: var(--text-2xl); }
  .ty-scale__sample--xl  { font-size: var(--text-xl); }
  .ty-scale__sample--lg  { font-size: var(--text-lg); }
  .ty-scale__sample--md  { font-size: var(--text-md); font-family: var(--font-sans); font-weight: 400; }
  .ty-scale__sample--base { font-size: var(--text-base); font-family: var(--font-sans); font-weight: 400; }
  .ty-scale__sample--sm  { font-size: var(--text-sm); font-family: var(--font-sans); font-weight: 400; color: var(--color-muted); }
  .ty-scale__sample--xs  { font-size: var(--text-xs); font-family: var(--font-sans); font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-muted); }

  /* ── Styles ─────────────────────────────────────────────────── */
  .ty-styles {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ty-style {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ty-style__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ochre);
  }

  .ty-style__spec {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  /* ── Prose demo ────────────────────────────────────────────── */
  .ty-prose-demo {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-8) var(--space-8);
  }

  /* ── Line heights ──────────────────────────────────────────── */
  .ty-leading {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
  }

  .ty-leading__row {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-5) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .ty-leading__token {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ochre);
  }

  .ty-leading__sample {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-ink);
  }

  .ty-leading__sample--tight  { line-height: 1.2; }
  .ty-leading__sample--snug   { line-height: 1.35; }
  .ty-leading__sample--base   { line-height: 1.6; }
  .ty-leading__sample--loose  { line-height: 1.8; }

  /* ── last section bottom padding ──────────────────────────── */
  .ty-section:last-child {
    margin-bottom: var(--space-20);
  }
</style>
