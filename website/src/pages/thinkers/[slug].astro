---
import Base from '../../layouts/Base.astro';
import AsciiPortrait from '../../components/AsciiPortrait.astro';

export async function getStaticPaths() {
  const thinkers = await Astro.glob('../../content/thinkers/*.md');
  return thinkers.map((t) => ({
    params: { slug: t.frontmatter.slug },
    props: { thinker: t },
  }));
}

const { thinker } = Astro.props;
const { name, dates, field, quote, lenses = [], website, books = [], talks = [], portrait, portrait_credit } = thinker.frontmatter;

---

<Base title={name} description={`${name} — ${field}`}>
  <section class="container thinker-header">
    <a href="/thinkers" class="back-link">← All thinkers</a>
    <div class="thinker-header__layout">
      <div class="thinker-header__meta">
        <p class="thinker-header__field">{field}</p>
        <h1 class="thinker-header__name">{name}</h1>
        <p class="thinker-header__dates">{dates}</p>
      </div>
      <div class="thinker-header__portrait-wrap">
        <div class="thinker-header__portrait-frame">
          <AsciiPortrait
            id={thinker.frontmatter.slug}
            name={name}
            photo={portrait}
          />
        </div>
        {portrait_credit && <p class="thinker-header__credit">{portrait_credit}</p>}
      </div>
    </div>
  </section>

  {quote && (
    <section class="container reading-column">
      <blockquote class="pull-quote">
        <p class="pull-quote__text">"{quote}"</p>
        <p class="pull-quote__attribution">— {name}</p>
      </blockquote>
    </section>
  )}

  <section class="container reading-column thinker-prose">
    <div class="prose" set:html={thinker.compiledContent()} />
  </section>

  {(books.length > 0 || talks.length > 0 || website) && (
    <section class="container reading-column thinker-resources">
      <div class="resources-block">
        <h2 class="resources-heading">Read &amp; Watch</h2>

        {books.length > 0 && (
          <div class="resources-group">
            <span class="resources-label">Books</span>
            <ul class="resource-list">
              {books.map((book) => {
                const goodreadsUrl = `https://www.goodreads.com/search?q=${encodeURIComponent(book.title + ' ' + name)}`;
                return (
                  <li class="resource-item resource-item--book">
                    <a href={goodreadsUrl} target="_blank" rel="noopener noreferrer" class="resource-item__link">
                      <div class="resource-item__cover"
                           data-cover-title={book.title}
                           data-cover-author={name}>
                        <div class="resource-item__cover-placeholder" aria-hidden="true"></div>
                      </div>
                      <div class="resource-item__body">
                        <div class="resource-item__title">{book.title} <span class="resource-item__ext">↗</span></div>
                        <div class="resource-item__meta">{book.year}</div>
                        <p class="resource-item__description">{book.description}</p>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {talks.length > 0 && (
          <div class="resources-group">
            <span class="resources-label">Talks</span>
            <ul class="resource-list">
              {talks.map((talk) => {
                const talkUrl = talk.url
                  ? talk.url
                  : `https://www.youtube.com/results?search_query=${encodeURIComponent(talk.title + ' ' + name)}`;
                return (
                  <li class="resource-item resource-item--talk">
                    <a href={talkUrl} target="_blank" rel="noopener noreferrer" class="resource-item__link">
                      <div class="resource-item__body">
                        <div class="resource-item__title">{talk.title} <span class="resource-item__ext">↗</span></div>
                        <div class="resource-item__meta">{talk.year} · {talk.platform}</div>
                        <p class="resource-item__description">{talk.description}</p>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {website && (
          <div class="resources-group">
            <span class="resources-label">Online</span>
            <a href={website} class="website-link" target="_blank" rel="noopener noreferrer">
              Official site / archive →
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  {lenses.length > 0 && (
    <section class="container reading-column thinker-connections">
      <div class="lens-connections">
        <div class="lens-connections__group">
          <span class="lens-connections__label">Lenses</span>
          <div class="lens-connections__tags">
            {lenses.map((slug) => (
              <a href={`/lenses/${slug}`} class="connection-tag">
                {slug.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .thinker-header {
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: var(--space-12);
  }
  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-8);
    transition: color 0.15s ease;
  }
  .back-link:hover { color: var(--color-ochre); }

  .thinker-header__layout {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
  }
  .thinker-header__meta {
    flex: 1;
  }
  .thinker-header__field {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ochre);
    margin-bottom: var(--space-3);
  }
  .thinker-header__name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    font-stretch: expanded;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .thinker-header__dates {
    font-size: var(--text-sm);
    color: var(--color-muted);
    font-style: italic;
  }
  .thinker-header__portrait-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }
  .thinker-header__portrait-frame {
    width: 160px;
    height: 160px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .thinker-header__credit {
    font-size: 10px;
    color: var(--color-muted);
    opacity: 0.6;
    max-width: 160px;
    text-align: right;
    line-height: 1.4;
  }

  .thinker-prose {
    padding-bottom: var(--space-10);
  }

  /* ── Resources ─────────────────────────────────────── */

  .thinker-resources {
    padding-bottom: var(--space-12);
  }

  .resources-block {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .resources-heading {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 800;
    font-stretch: expanded;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: var(--space-2);
  }

  .resources-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .resources-label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .resource-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .resource-item {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .resource-item__link {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-base);
  }

  .resource-item__link:hover {
    border-color: var(--color-ink);
  }

  /* ── Book cover ── */
  .resource-item__cover {
    flex-shrink: 0;
    width: 68px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-rule);
    align-self: flex-start;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .resource-item__cover-placeholder {
    width: 68px;
    aspect-ratio: 2 / 3;
    background: linear-gradient(135deg, var(--color-rule) 25%, var(--color-surface) 50%, var(--color-rule) 75%);
    background-size: 200% 200%;
    animation: shimmer 1.4s ease infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .resource-item__cover-img {
    width: 68px;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .resource-item__cover-img.loaded {
    opacity: 1;
  }

  /* ── Content body ── */
  .resource-item__body {
    flex: 1;
    min-width: 0;
  }

  .resource-item__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    margin-bottom: var(--space-1);
    line-height: var(--leading-snug);
  }

  .resource-item__ext {
    font-size: 0.7em;
    color: var(--color-muted);
    margin-left: 2px;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .resource-item__link:hover .resource-item__ext {
    opacity: 1;
  }

  .resource-item__meta {
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .resource-item__description {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: var(--leading-base);
  }

  .website-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-ochre);
    transition: color 0.15s ease;
  }
  .website-link:hover { color: var(--color-ochre-d); }

  /* ── Connections ───────────────────────────────────── */

  .thinker-connections {
    padding-bottom: var(--space-20);
  }

  .lens-connections {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule);
  }
  .lens-connections__group {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .lens-connections__label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    min-width: 5rem;
  }
  .lens-connections__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>

<script>
  async function loadBookCovers() {
    const covers = document.querySelectorAll<HTMLElement>('.resource-item__cover[data-cover-title]');
    await Promise.all(Array.from(covers).map(async (cover) => {
      const title = cover.dataset.coverTitle!;
      const author = cover.dataset.coverAuthor!;
      try {
        const res = await fetch(
          `https://openlibrary.org/search.json?title=${encodeURIComponent(title)}&author=${encodeURIComponent(author)}&fields=cover_i&limit=1`
        );
        const data = await res.json();
        const coverId = data?.docs?.[0]?.cover_i;
        if (!coverId) return;
        const img = document.createElement('img');
        img.src = `https://covers.openlibrary.org/b/id/${coverId}-L.jpg`;
        img.alt = `${title} cover`;
        img.className = 'resource-item__cover-img';
        img.onload = () => img.classList.add('loaded');
        cover.innerHTML = '';
        cover.appendChild(img);
      } catch { /* no cover available */ }
    }));
  }

  loadBookCovers();
</script>
